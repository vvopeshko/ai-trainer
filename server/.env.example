# Backend environment example.
# Скопируй в server/.env и заполни. НИКОГДА не коммить заполненный .env.

# ─── Инфраструктура ─────────────────────────────────────────────
# Neon Postgres URL (через https://neon.tech). PITR — обязателен.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

NODE_ENV=development
PORT=3001

# ─── Telegram ───────────────────────────────────────────────────
# Получить через @BotFather → /newbot
BOT_TOKEN=

# Frontend URL мини-аппа (локально или прод Vercel).
FRONTEND_URL=http://localhost:5173
# URL, который подставляется в Menu Button и inline-клавиатуру.
WEBAPP_URL=http://localhost:5173

# ─── AI ─────────────────────────────────────────────────────────
# Anthropic API key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Cloudflare R2 (фото тренажёров) ────────────────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=ai-trainer-photos
R2_ENDPOINT=

# ─── Сервисное ──────────────────────────────────────────────────
# Секрет для админ-эндпоинтов /api/v1/analytics/*
ANALYTICS_SECRET=change-me-to-random-string
# Твой telegramId (для будущих админ-фич)
ADMIN_TELEGRAM_ID=
